<Window x:Class="Budweg.Views.ReceiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modtag Kaliber" Height="600" Width="380" 
        Background="#F2F2F7" WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Modtag Ny Kaliber" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Indtast Stregkode:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border CornerRadius="8" BorderThickness="1" BorderBrush="#D1D1D6" Background="White" Margin="0,0,0,15">
                <TextBox x:Name="txtBarcode" Height="40" VerticalContentAlignment="Center" Padding="10" BorderThickness="0" Background="Transparent"/>
            </Border>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="2" Height="50">
            <Button Content="Annuller" Margin="0,0,5,0" Click="BtnCancel_Click" Background="#E5E5EA"/>

            <Button Content="Registrer" Margin="5,0,0,0" Click="BtnRegister_Click" Foreground="White" FontWeight="Bold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#34C759"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text.Length, ElementName=txtBarcode}" Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text.Length, ElementName=txtOrderNumber}" Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AEAEB2"/>
                                <Setter Property="Foreground" Value="#F2F2F7"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#28A745"/>
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </UniformGrid>
    </Grid>
</Window>