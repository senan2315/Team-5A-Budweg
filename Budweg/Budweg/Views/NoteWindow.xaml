<Window x:Class="Budweg.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Noter" Height="600" Width="380" 
        Background="#F2F2F7" WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Noter for Caliper" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,20">
            <ScrollViewer>
                <TextBlock x:Name="txtPreviousNotes" TextWrapping="Wrap" FontSize="14" Foreground="#3A3A3C"
                           Text="[10:15 - Modtagelse]: Caliper ser fin ud.&#x0a;[11:30 - Adskillelse]: Rust fundet på stemplet."/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Skriv ny note:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border CornerRadius="8" BorderThickness="1" BorderBrush="#D1D1D6" Background="White">
                <TextBox x:Name="txtNewNote" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalContentAlignment="Top" Padding="10" BorderThickness="0" Background="Transparent"/>
            </Border>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Annuller" Grid.Column="0" Margin="0,0,5,0" Height="45" Click="BtnCancel_Click" Background="#E5E5EA">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Gem Note" Grid.Column="1" Margin="5,0,0,0" Height="45" Click="BtnSave_Click" Background="#34C759" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>